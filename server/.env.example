mongodb+srv://kat_school:kat_school@cluster0.xslsofa.mongodb.net/?appName=Cluster0

# ============================================
# KAT SCHOOL MANAGEMENT SYSTEM
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to git

# ─── Server ─────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ──────────────────────────
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/kat_school?retryWrites=true&w=majority

# ─── JWT Secrets ────────────────────────────
# Use strong random strings — minimum 64 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_very_strong_access_secret_minimum_64_characters_here
JWT_REFRESH_SECRET=your_very_strong_refresh_secret_minimum_64_characters_here
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ─── AI — Anthropic Claude ──────────────────
# Get your key from: https://console.anthropic.com/settings/keys
# Used for: Academic Assistant, School Chatbot, Notice Writer,
#           Report Card Comments, Exam Question Generator
ANTHROPIC_API_KEY=sk-ant-api03-your_claude_api_key_here

# ─── AI — OpenAI GPT-4 ──────────────────────
# Get your key from: https://platform.openai.com/api-keys
# Used for: Performance Predictor, Attendance Analyzer,
#           Fee Default Predictor, Timetable Generator, Book Recommender
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# ─── Anthropic Model ────────────────────────
ANTHROPIC_MODEL=claude-opus-4-5

# ─── Email — Nodemailer ─────────────────────
# For Gmail: enable 2FA then create App Password
# App Password guide: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_school_email@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM_NAME=Kat Secondary School
EMAIL_FROM_ADDRESS=no-reply@katschool.edu.et

# ─── Client URL ─────────────────────────────
# Used for CORS and password reset email links
CLIENT_URL=http://localhost:5173

# ─── Cloudinary ─────────────────────────────
# For profile photos and document uploads
# Get from: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=kat_school_uploads

# ─── File Upload Limits ──────────────────────
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ─── Rate Limiting ───────────────────────────
# Number of requests allowed per window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─── Bcrypt ──────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Pagination Defaults ────────────────────
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ─── School Info ─────────────────────────────
# Used in emails, PDF reports, and report cards
SCHOOL_NAME=Kat Secondary School
SCHOOL_ADDRESS=Addis Ababa, Ethiopia
SCHOOL_PHONE=+251-11-XXX-XXXX
SCHOOL_EMAIL=info@katschool.edu.et
SCHOOL_WEBSITE=www.katschool.edu.et
SCHOOL_MOTTO=Excellence in Education

# ─── Ethiopian Academic Settings ─────────────
CURRENT_ACADEMIC_YEAR=2016
CURRENT_TERM=2
ETHIOPIAN_CALENDAR=true

# ─── Logging ─────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ─── Cookie ──────────────────────────────────
COOKIE_SECRET=your_cookie_secret_here
COOKIE_EXPIRE_DAYS=7