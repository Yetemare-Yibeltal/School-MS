# ============================================
# KAT SCHOOL SERVER — .gitignore
# ============================================

# ─── Environment Variables ──────────────────
.env
.env.local
.env.development
.env.production
.env.test

# ─── Dependencies ───────────────────────────
node_modules/

# ─── Logs ───────────────────────────────────
logs/
*.log
npm-debug.log*

# ─── Upload Folders ─────────────────────────
uploads/photos/*
uploads/documents/*
!uploads/photos/.gitkeep
!uploads/documents/.gitkeep

# ─── Generated Export Files ─────────────────
exports/
generated/
*.pdf
*.xlsx
*.xls
*.csv

# ─── Puppeteer Cache ────────────────────────
.local-chromium/
.cache/puppeteer/

# ─── OS Files ───────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Testing ────────────────────────────────
coverage/
.nyc_output/

# ─── Temporary ──────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ─── SSL Certificates ───────────────────────
*.pem
*.key
*.cert
*.p12

# ─── Build ──────────────────────────────────
dist/
build/