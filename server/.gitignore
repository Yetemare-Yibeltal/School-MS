# ============================================
# KAT SCHOOL MANAGEMENT SYSTEM — .gitignore
# ============================================

# ─── Dependencies ───────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ─── Environment Variables ──────────────────
.env
.env.local
.env.development
.env.production
.env.test
server/.env
client/.env

# ─── Build Output ───────────────────────────
dist/
build/
client/dist/
client/build/

# ─── Logs ───────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Upload Folders ─────────────────────────
server/uploads/photos/*
server/uploads/documents/*
!server/uploads/photos/.gitkeep
!server/uploads/documents/.gitkeep

# ─── OS Files ───────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE & Editor ───────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.history/

# ─── Testing ────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Cache ──────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ─── Temporary Files ────────────────────────
tmp/
temp/
*.tmp
*.temp

# ─── PDF & Excel Exports ────────────────────
server/exports/
client/public/exports/

# ─── Docker ─────────────────────────────────
.dockerignore

# ─── Misc ───────────────────────────────────
*.pem
*.key
*.cert
*.p12
.vercel
.netlify