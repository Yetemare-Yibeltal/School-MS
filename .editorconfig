# ============================================
# KAT SCHOOL MANAGEMENT SYSTEM — .editorconfig
# ============================================
# editorconfig.org

root = true

# ─── All Files ──────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ─── JavaScript & JSX ───────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 2
quote_type = single

# ─── JSON ───────────────────────────────────
[*.json]
indent_size = 2

# ─── CSS & SCSS ─────────────────────────────
[*.{css,scss,less}]
indent_size = 2

# ─── HTML ───────────────────────────────────
[*.html]
indent_size = 2

# ─── Markdown ───────────────────────────────
[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# ─── YAML ───────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── Environment Files ───────────────────────
[*.env*]
insert_final_newline = true

# ─── Shell Scripts ──────────────────────────
[*.sh]
end_of_line = lf
indent_size = 2

# ─── Docker ─────────────────────────────────
[Dockerfile*]
indent_size = 2

# ─── Package Files ──────────────────────────
[package.json]
indent_size = 2

# ─── Git Config ─────────────────────────────
[.gitconfig]
indent_style = tab