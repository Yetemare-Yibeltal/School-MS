# ============================================
# KAT SCHOOL CLIENT — ENVIRONMENT VARIABLES
# ============================================ 
# NEVER commit the actual .env file to git
# All variables MUST start with VITE_ to be
# accessible in the React app

# ─── API Configuration ───────────────────────
# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# ─── App Info ────────────────────────────────
VITE_APP_NAME=Kat School MS
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered School Management System

# ─── School Info ─────────────────────────────
VITE_SCHOOL_NAME=Kat Secondary School
VITE_SCHOOL_ADDRESS=Addis Ababa, Ethiopia
VITE_SCHOOL_EMAIL=info@katschool.edu.et
VITE_SCHOOL_PHONE=+251-11-XXX-XXXX
VITE_SCHOOL_WEBSITE=www.katschool.edu.et

# ─── Feature Flags ───────────────────────────
# Set to true or false to enable/disable features
VITE_ENABLE_AI=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_CHAT=true

# ─── Pagination ──────────────────────────────
VITE_DEFAULT_PAGE_SIZE=10

# ─── Token Storage ───────────────────────────
# Key names used in localStorage
VITE_ACCESS_TOKEN_KEY=kat_access_token
VITE_REFRESH_TOKEN_KEY=kat_refresh_token
VITE_USER_KEY=kat_user

# ─── Theme ───────────────────────────────────
VITE_DEFAULT_THEME=light

# ─── Timeout ─────────────────────────────────
# API request timeout in milliseconds
VITE_API_TIMEOUT=30000

# ─── Ethiopian Settings ──────────────────────
VITE_CURRENCY=ETB
VITE_CURRENCY_SYMBOL=ብር
VITE_CALENDAR=ethiopian
VITE_LANGUAGE=en